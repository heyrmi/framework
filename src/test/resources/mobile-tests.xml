<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Mobile Test Suite" parallel="classes" thread-count="1">
    <!-- Mobile: thread-count=1 unless running on cloud device farm -->
    <listeners>
        <listener class-name="ra.hul.framework.core.listeners.AllureTestListener"/>
        <listener class-name="ra.hul.framework.core.listeners.RetryTransformer"/>
    </listeners>

    <test name="Mobile Tests">
        <classes>
            <class name="ra.hul.tests.mobile.LoginMobileTest"/>
            <class name="ra.hul.tests.mobile.SwipeGestureTest"/>
            <class name="ra.hul.tests.mobile.FormInteractionTest"/>
            <class name="ra.hul.tests.mobile.NavigationTest"/>
            <class name="ra.hul.tests.mobile.WebViewTest"/>
        </classes>
    </test>
</suite>
